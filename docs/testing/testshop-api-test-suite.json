  "item": [
    {
      "name": "01 - Authentication",
      "item": [
        {
          "name": "[AUTH-001] Register Success (Happy Path)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('สมัครสมาชิกสำเร็จ', function() {",
                  "    pm.expect(pm.response.status).to.equal('Created');",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userEmail', json.data.user.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user{{$randomInt}}@test.com\", \"password\": \"Test123456\", \"fullName\": \"Test User\"}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "[AUTH-002] Register Duplicate Email (Error 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('สมัครซ้ำต้องได้ 409', function() {",
                  "    pm.expect(pm.response.status).to.equal(409);",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"duplicate@test.com\", \"password\": \"Test123456\", \"fullName\": \"Duplicate User\"}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "[AUTH-004] Register Missing Fields (Error 400)",
