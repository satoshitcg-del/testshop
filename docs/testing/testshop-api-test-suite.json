{
  "info": {
    "_postman_id": "testshop-api-test-suite",
    "name": "TestShop API Test Suite",
    "description": "Comprehensive Postman Test Suite - Integration + E2E Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://testshop-lr30.onrender.com", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "userEmail", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "cartItemId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "otherUserOrderId", "value": "", "type": "string" }
